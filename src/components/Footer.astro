---
/**
 * Footer.astro
 * ─────────────────────────────────────────────────────────────────────────────
 * Site-wide footer with copyright, navigation links, and an RSS link.
 */

const year = new Date().getFullYear();

const FOOTER_LINKS = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About Us' },
  { href: '/blog', label: 'Updates' },
  { href: 'https://www.facebook.com/opentrailsca', label: 'Facebook', external: true },
  { href: '/rss.xml', label: 'RSS', external: true },
];
---

<footer class="border-t border-gray-200 bg-white dark:border-gray-700 dark:bg-gray-900">
  <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <div class="flex flex-col items-center gap-6 sm:flex-row sm:justify-between">
      <!-- Site name -->
      <p class="text-sm font-semibold text-gray-900 dark:text-white">
        Open Trails Community Alliance
      </p>

      <!-- Footer navigation -->
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap justify-center gap-x-6 gap-y-2 list-none m-0 p-0">
          {FOOTER_LINKS.map(({ href, label, external }) => (
            <li>
              <a
                href={href}
                class="text-sm text-gray-500 no-underline hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors"
                rel={external ? 'noopener noreferrer' : undefined}
                target={external ? '_blank' : undefined}
              >
                {label}
                {external && (
                  <span class="sr-only">(opens in new tab)</span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Copyright -->
    <p class="mt-8 text-center text-xs text-gray-500 dark:text-gray-400">
      &copy; {year} Open Trails Community Alliance. Meadow Vista, CA.
    </p>
    <p class="mt-2 text-center text-xs text-gray-500 dark:text-gray-400">
      Made by <a href="https://www.switchbacksolutions.net" class="underline hover:text-gray-600 dark:hover:text-gray-300 transition-colors" rel="noopener noreferrer" target="_blank">Switchback Solutions</a>
    </p>
  </div>
</footer>
